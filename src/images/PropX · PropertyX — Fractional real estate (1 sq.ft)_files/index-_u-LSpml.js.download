        .payment-icon {
          width: 48px;
          height: 48px;
          border-radius: 12px;
          background: rgba(40, 167, 69, 0.1);
          display: flex;
          align-items: center;
          justify-content: center;
        }
        .bank-detail-item {
          padding: 10px;
          border: 1px solid #e9ecef;
          border-radius: 8px;
          background: #fff;
        }
        .bank-detail-item label {
          display: block;
          margin-bottom: 4px;
          font-size: 11px;
          text-transform: uppercase;
          letter-spacing: 0.5px;
        }
        .bank-detail-item .fw-medium {
          font-family: 'Courier New', monospace;
