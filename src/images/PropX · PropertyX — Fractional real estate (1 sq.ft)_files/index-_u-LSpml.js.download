        .confirmation-icon {
          width: 48px;
          height: 48px;
          border-radius: 12px;
          background: rgba(40, 167, 69, 0.1);
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .summary-item {
          padding: 12px;
          border: 1px solid #e9ecef;
          border-radius: 8px;
          background: #fff;
        }

        .summary-item label {
          display: block;
          margin-bottom: 4px;
          font-size: 12px;
          text-transform: uppercase;
          letter-spacing: 0.5px;
        }

        .verification-steps {
          display: flex;
          flex-direction: column;
          gap: 16px;
        }

        .step-item {
          display: flex;
          align-items: center;
          gap: 12px;
        }

        .step-icon {
          width: 32px;
          height: 32px;
          border-radius: 50%;
          display: flex;
          align-items: center;
          justify-content: center;
          background: #f8f9fa;
          border: 2px solid #e9ecef;
        }

        .step-item.completed .step-icon {
          background: rgba(40, 167, 69, 0.1);
          border-color: #28a745;
        }

        .step-item.active .step-icon {
          background: rgba(255, 193, 7, 0.1);
          border-color: #ffc107;
        }

        .step-content {
          flex: 1;
        }
